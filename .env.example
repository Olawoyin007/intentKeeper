# IntentKeeper Configuration
# Copy this file to .env and configure

# Ollama settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TEMPERATURE=0.1

# Server settings
INTENTKEEPER_PORT=8420
INTENTKEEPER_HOST=127.0.0.1

# Classification settings
# Threshold above which content is considered manipulative (0.0-1.0)
MANIPULATION_THRESHOLD=0.6

# Enable debug logging
DEBUG=false

# Cache settings (seconds)
CACHE_TTL=300

# Optional: pin the Ollama sampling seed for reproducible classifications.
# Same prompt + same seed + same model = identical output every run.
# Set to any integer (e.g. 42). Unset means non-deterministic (default).
# OLLAMA_SEED=42
